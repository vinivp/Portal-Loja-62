VITE_FIREBASE_API_KEY=cole_sua_api_key
VITE_FIREBASE_AUTH_DOMAIN=seu-projeto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=seu-projeto
VITE_FIREBASE_STORAGE_BUCKET=seu-projeto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000

# true = usa Firebase Authentication com email/senha.
# false = usa o login local do portal, mas ainda pode sincronizar dados no Firestore se as regras permitirem.
VITE_FIREBASE_AUTH_ENABLED=false
